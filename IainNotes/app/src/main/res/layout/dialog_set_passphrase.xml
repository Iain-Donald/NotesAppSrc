<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Set passphrase"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etNewPassphrase"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="New passphrase"
        android:inputType="textPassword"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etConfirmPassphrase"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Confirm passphrase"
        android:inputType="textPassword"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/etNewPassphrase"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnConfirmPassphrase"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Set passphrase"
        app:backgroundTint="@color/exp5"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/etConfirmPassphrase"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnCancelPassphrase"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Cancel"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/btnConfirmPassphrase"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>