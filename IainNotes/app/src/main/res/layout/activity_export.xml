<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:padding="24dp">

    <TextView
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:textSize="16sp"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvPlainDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Plain tar — decrypted, readable by any tar tool. Share only with people you trust."
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnExportPlain"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Export decrypted (.tar)"
        android:layout_marginTop="8dp"
        app:backgroundTint="@color/exp5"
        app:layout_constraintTop_toBottomOf="@id/tvPlainDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#22000000"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnExportPlain"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvEncryptedDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Encrypted tar — requires your passphrase to open. Safe to store anywhere."
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnExportEncrypted"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Export encrypted (.tar.enc)"
        android:layout_marginTop="8dp"
        app:backgroundTint="@color/exp5"
        app:layout_constraintTop_toBottomOf="@id/tvEncryptedDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnExportEncrypted"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>